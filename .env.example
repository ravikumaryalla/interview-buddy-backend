# ─── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/interview_buddy"

# ─── Redis ────────────────────────────────────────────────
# Format: redis://[:password@]HOST:PORT[/db]
REDIS_URL="redis://localhost:6379"

# ─── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_super_secret_jwt_key_replace_this_in_production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your_super_secret_refresh_key_replace_this_in_production"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Email (Nodemailer) ───────────────────────────────────
# For development use Mailtrap: https://mailtrap.io
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER="your_mailtrap_user"
SMTP_PASS="your_mailtrap_password"
SMTP_FROM="Interview Buddy <noreply@interviewbuddy.app>"

# ─── App ──────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
# Free credits awarded on registration
FREE_CREDITS_ON_SIGNUP=20
